# PaletteForge .gitignore

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Build outputs
build/
dist/
*.egg-info/

# Test/cache folders
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS files
.DS_Store
Thumbs.db

# Editor folders
.vscode/
.idea/

# PaletteForge generated exports
exports/*
!exports/.gitkeep

# Temporary files
*.tmp
*.bak
*.log
